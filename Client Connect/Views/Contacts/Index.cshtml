@{
    ViewBag.Title = "Contacts";
}

<div class="d-flex justify-content-between align-items-center page-header">
    <h2><i class="fas fa-address-book mr-2 text-primary"></i>Contacts</h2>
    <a href="/Contacts/Create" class="btn btn-primary">
        <i class="fas fa-plus mr-1"></i> New Contact
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            Swal.fire({ icon: 'success', title: 'Success', text: '@TempData["SuccessMessage"]', timer: 3000, showConfirmButton: false });
        });
    </script>
}

<div class="card">
    <div class="card-header">
        <i class="fas fa-list mr-2"></i>Contact List
    </div>
    <div class="card-body">
        <table id="contactsTable" class="table table-hover w-100">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Surname</th>
                    <th>Email Address</th>
                    <th style="text-align:center">No. of Linked Clients</th>
                    <th style="text-align:center">Status</th>
                    <th style="text-align:center">Options</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap4.min.css" />
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap4.min.js"></script>

    <script>
        var table;

        $(document).ready(function () {
            table = $('#contactsTable').DataTable({
                ajax: {
                    url: '/Contacts/GetAll',
                    type: 'GET',
                    dataSrc: ''
                },
                order: [[1, 'asc'], [0, 'asc']],
                stateSave: true,
                stateSaveCallback: function (settings, data) {
                    CookieHelper.set('DataTables_contactsTable', JSON.stringify(data), 0);
                },
                stateLoadCallback: function (settings) {
                    var saved = CookieHelper.get('DataTables_contactsTable');
                    return saved ? JSON.parse(saved) : null;
                },
                language: {
                    emptyTable: 'No contact(s) found.',
                    zeroRecords: 'No contact(s) match your search.'
                },
                columns: [
                    { data: 'Name', className: 'text-left' },
                    { data: 'Surname', className: 'text-left' },
                    { data: 'Email', className: 'text-left' },
                    { data: 'ClientCount', className: 'text-center' },
                    {
                        data: 'StateId',
                        className: 'text-center',
                        orderable: false,
                        render: function (data) {
                            return data === 1
                                ? '<span class="badge badge-success">Active</span>'
                                : '<span class="badge badge-danger">Deleted</span>';
                        }
                    },
                    {
                        data: 'Options',
                        className: 'text-center',
                        orderable: false,
                        searchable: false,
                        createdCell: function (td, cellData) {
                            $(td).html(cellData);
                        }
                    }
                ]
            });
        });

        // ── Toggle State ────────────────────────────────────────
        $(document).on('click', '.btn-toggle-contact', function (e) {
            e.preventDefault();
            var contactId = $(this).data('id');
            var contactName = $(this).data('name');
            var currentState = $(this).data('state');
            var actionLabel = currentState === 1 ? 'Delete' : 'Set Active';
            var action = currentState === 1 ? 'deactivate' : 'reactivate';

            Swal.fire({
                title: actionLabel + '?',
                text: 'Are you sure you want to ' + action + ' "' + contactName + '"?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: currentState === 1 ? '#e0a800' : '#28a745',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, ' + actionLabel,
                cancelButtonText: 'Cancel'
            }).then(function (result) {
                if (result.isConfirmed) {
                    $.post('/Contacts/ToggleState', { id: contactId }, function (res) {
                        if (res.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Updated!',
                                text: '"' + contactName + '" has been ' + action + 'd.',
                                timer: 2000,
                                showConfirmButton: false
                            }).then(function () { table.ajax.reload(); });
                        } else {
                            Swal.fire({ icon: 'error', title: 'Error', text: res.message });
                        }
                    });
                }
            });
        });

        // ── Delete ──────────────────────────────────────────────
        $(document).on('click', '.btn-delete-contact', function (e) {
            e.preventDefault();
            var contactId = $(this).data('id');
            var contactName = $(this).data('name');

            Swal.fire({
                title: 'Delete Contact?',
                text: 'Are you sure you want to delete "' + contactName + '"?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, Delete',
                cancelButtonText: 'Cancel'
            }).then(function (result) {
                if (result.isConfirmed) {
                    $.post('/Contacts/Delete', { id: contactId }, function (res) {
                        if (res.success) {
                            Swal.fire({
                                icon: 'success', title: 'Deleted!',
                                text: '"' + contactName + '" has been deleted.',
                                timer: 2000, showConfirmButton: false
                            }).then(function () { table.ajax.reload(); });
                        } else {
                            Swal.fire({ icon: 'error', title: 'Error', text: res.message });
                        }
                    });
                }
            });
        });
    </script>
}