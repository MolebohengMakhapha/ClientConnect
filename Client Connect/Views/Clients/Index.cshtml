@{
    ViewBag.Title = "Clients";
}

<div class="d-flex justify-content-between align-items-center page-header">
    <h2><i class="fas fa-users mr-2 text-primary"></i>Clients</h2>
    <a href="/Clients/Create" class="btn btn-primary">
        <i class="fas fa-plus mr-1"></i> New Client
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            Swal.fire({ icon: 'success', title: 'Success', text: '@TempData["SuccessMessage"]', timer: 3000, showConfirmButton: false });
        });
    </script>
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="fas fa-list mr-2"></i>Client List</span>
        <div class="d-flex align-items-center">
            <label class="mb-0 mr-2 text-muted small font-weight-bold">State:</label>
            <select id="stateFilter" class="form-control form-control-sm" style="width: 140px;">
                <option value="">All States</option>
                <option value="1" selected>Active</option>
                <option value="0">Deleted</option>
            </select>
        </div>
    </div>
    <div class="card-body">
        <table id="clientsTable" class="table table-hover w-100">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Client Code</th>
                    <th style="text-align:center">No. of Linked Contacts</th>
                    <th style="text-align:center">Status</th>
                    <th style="text-align:center">Options</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap4.min.css" />
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap4.min.js"></script>

    <script>
        var table;
        var activeStateFilter = localStorage.getItem('clientsStateFilter') || '1';; 

        document.addEventListener('DOMContentLoaded', function () {
            $('#stateFilter').val(activeStateFilter);
        });

        // Custom filter function registered once
        $.fn.dataTable.ext.search.push(function (settings, data, dataIndex, rowData) {
            if (settings.nTable.id !== 'clientsTable') return true;
            if (activeStateFilter === '') return true;
            return String(rowData.StateId) === activeStateFilter;
        });

        $(document).ready(function () {
            table = $('#clientsTable').DataTable({
                ajax: {
                    url: '/Clients/GetAll',
                    type: 'GET',
                    dataSrc: ''
                },
                order: [[0, 'asc']],
                stateSave: true,
                stateSaveCallback: function (settings, data) {
                    localStorage.setItem('DataTables_clientsTable', JSON.stringify(data));
                },
                stateLoadCallback: function (settings) {
                    var saved = localStorage.getItem('DataTables_clientsTable');
                    return saved ? JSON.parse(saved) : null;
                },
                language: {
                    emptyTable: 'No client(s) found.',
                    zeroRecords: 'No client(s) match your search.'
                },
                columns: [
                    { data: 'Name', className: 'text-left' },
                    { data: 'ClientCode', className: 'text-left' },
                    { data: 'ContactCount', className: 'text-center' },
                    {
                        data: 'StateId',
                        className: 'text-center',
                        orderable: false,
                        render: function (data) {
                            return data === 1
                                ? '<span class="badge badge-success">Active</span>'
                                : '<span class="badge badge-danger">Deleted</span>';
                        }
                    },
                    {
                        data: 'Options',
                        className: 'text-center',
                        orderable: false,
                        searchable: false,
                        createdCell: function (td, cellData) {
                            $(td).html(cellData);
                        }
                    }
                ]
            });

            $('#stateFilter').on('change', function () {
                activeStateFilter = $(this).val();
                localStorage.setItem('clientsStateFilter', activeStateFilter);
                table.draw();
            });
        });

        // ── Toggle State ────────────────────────────────────────
        $(document).on('click', '.btn-toggle-client', function (e) {
            e.preventDefault();
            var clientId = $(this).data('id');
            var clientName = $(this).data('name');
            var currentState = $(this).data('state');
            var actionLabel = currentState === 1 ? 'Delete' : 'Set Active';
            var action = currentState === 1 ? 'deactivate' : 'reactivate';

            Swal.fire({
                title: actionLabel + '?',
                text: 'Are you sure you want to ' + action + ' "' + clientName + '"?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: currentState === 1 ? '#e0a800' : '#28a745',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, ' + actionLabel,
                cancelButtonText: 'Cancel'
            }).then(function (result) {
                if (result.isConfirmed) {
                    $.post('/Clients/ToggleState', { id: clientId }, function (res) {
                        if (res.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Updated!',
                                text: '"' + clientName + '" has been ' + action + 'd.',
                                timer: 2000,
                                showConfirmButton: false
                            }).then(function () { table.ajax.reload(); });
                        } else {
                            Swal.fire({ icon: 'error', title: 'Error', text: res.message });
                        }
                    });
                }
            });
        });

        // ── Delete ──────────────────────────────────────────────
        $(document).on('click', '.btn-delete-client', function (e) {
            e.preventDefault();
            var clientId = $(this).data('id');
            var clientName = $(this).data('name');

            Swal.fire({
                title: 'Delete Client?',
                text: 'Are you sure you want to delete "' + clientName + '"?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, Delete',
                cancelButtonText: 'Cancel'
            }).then(function (result) {
                if (result.isConfirmed) {
                    $.post('/Clients/Delete', { id: clientId }, function (res) {
                        if (res.success) {
                            Swal.fire({
                                icon: 'success', title: 'Deleted!',
                                text: '"' + clientName + '" has been deleted.',
                                timer: 2000, showConfirmButton: false
                            }).then(function () { table.ajax.reload(); });
                        } else {
                            Swal.fire({ icon: 'error', title: 'Error', text: res.message });
                        }
                    });
                }
            });
        });
    </script>
}